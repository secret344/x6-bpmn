{
  "name": "x6-bpmn2-workspace",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "workspaces": [
    "packages/demo-vite-config",
    "packages/x6-plugin-bpmn",
    "packages/example",
    "packages/approval-flow",
    "packages/dialect-demo",
    "packages/smartengine-demo"
  ],
  "scripts": {
    "build:plugin": "pnpm --filter @x6-bpmn2/plugin build",
    "build:example": "pnpm --filter @x6-bpmn2/example build",
    "build:approval": "pnpm --filter @x6-bpmn2/approval-flow build",
    "build:dialect": "pnpm --filter @x6-bpmn2/dialect-demo build",
    "build:smartengine": "pnpm --filter @x6-bpmn2/smartengine-demo build",
    "build": "pnpm run build:plugin && pnpm run build:example",
    "test": "pnpm --filter @x6-bpmn2/plugin test",
    "test:coverage": "pnpm --filter @x6-bpmn2/plugin test:coverage",
    "test:plugin:browser": "pnpm --filter @x6-bpmn2/plugin test:browser",
    "dev": "pnpm --filter @x6-bpmn2/example dev",
    "dev:approval": "pnpm --filter @x6-bpmn2/approval-flow dev",
    "dev:dialect": "pnpm --filter @x6-bpmn2/dialect-demo dev",
    "dev:smartengine": "pnpm --filter @x6-bpmn2/smartengine-demo dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-istanbul": "^4.1.2"
  }
}
